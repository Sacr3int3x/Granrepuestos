{
  "entities": {
    "Brand": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Brand",
      "type": "object",
      "description": "Represents a brand of auto parts.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Brand entity." },
        "name": { "type": "string", "description": "The name of the brand." },
        "logoUrl": { "type": "string", "description": "URL of the brand's logo.", "format": "uri" },
        "description": { "type": "string", "description": "A detailed description of the brand." },
        "countryOfOrigin": { "type": "string", "description": "The country of origin for the brand." },
        "heroImageUrl": { "type": "string", "description": "URL for a hero image for the brand's detail page.", "format": "uri" },
        "websiteUrl": { "type": "string", "description": "URL of the brand's official website.", "format": "uri" }
      },
      "required": ["id", "name", "logoUrl"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a category of auto parts (e.g., Engine, Suspension, Body).",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Category entity." },
        "name": { "type": "string", "description": "The name of the category." }
      },
      "required": ["id", "name"]
    },
    "Part": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Part",
      "type": "object",
      "description": "Represents an auto part.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Part entity." },
        "brandId": { "type": "string", "description": "Reference to Brand. (Relationship: Brand 1:N Part)" },
        "name": { "type": "string", "description": "The name of the part." },
        "description": { "type": "string", "description": "A description of the part." },
        "sku": { "type": "string", "description": "The stock keeping unit code for the part." },
        "price": { "type": "number", "description": "The price of the part." },
        "stock": { "type": "number", "description": "The number of parts in stock." },
        "imageUrls": { "type": "array", "description": "URLs of the images for the part.", "items": { "type": "string" } },
        "categoryIds": { "type": "array", "description": "References to Categories. (Relationship: Category N:N Part)", "items": { "type": "string" } },
        "vehicleBrandId": { "type": "string", "description": "The brand of the vehicle this part is for." },
        "vehicleModelId": { "type": "string", "description": "The model of the vehicle this part is for." }
      },
      "required": ["id", "brandId", "name", "description", "sku", "price", "stock", "imageUrls"]
    },
    "PaymentReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PaymentReport",
      "type": "object",
      "description": "Represents a customer's payment report for an order.",
      "properties": {
        "id": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email", "description": "The customer's email for notifications." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "partId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["partId", "name", "price", "quantity"]
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending_verification", "verified", "rejected"], "default": "pending_verification" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentDetails": {
          "type": "object",
          "properties": {
            "referenceNumber": { "type": "string" },
            "bank": { "type": "string" },
            "phone": { "type": "string" },
            "idNumber": { "type": "string" },
            "amount": { "type": "number" },
            "paymentDate": { "type": "string", "format": "date" }
          },
           "required": ["referenceNumber", "bank", "amount", "paymentDate"]
        }
      },
      "required": ["customerEmail", "items", "totalAmount", "status", "createdAt", "paymentDetails"]
    },
    "admins": {
      "title": "Admin User",
      "description": "An empty document whose ID is the UID of a Firebase Auth user. The existence of this document indicates that the user has admin privileges. No properties are stored in the document itself.",
      "type": "object",
      "properties": {}
    }
  },
  "auth": { "providers": ["password", "anonymous"] },
  "firestore": {
    "structure": [
      {
        "path": "/brands/{brandId}",
        "definition": { "entityName": "Brand", "schema": { "$ref": "#/backend/entities/Brand" }, "description": "Stores brand information." }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": { "entityName": "Category", "schema": { "$ref": "#/backend/entities/Category" }, "description": "Stores category information." }
      },
      {
        "path": "/parts/{partId}",
        "definition": { "entityName": "Part", "schema": { "$ref": "#/backend/entities/Part" }, "description": "Stores auto part information." }
      },
      {
        "path": "/paymentReports/{reportId}",
        "definition": { "entityName": "PaymentReport", "schema": { "$ref": "#/backend/entities/PaymentReport" }, "description": "Stores payment reports submitted by customers. Publicly writable." }
      },
      {
        "path": "/admins/{uid}",
        "definition": { "entityName": "admins", "schema": { "$ref": "#/backend/entities/admins" }, "description": "Collection of admin users." }
      }
    ],
    "reasoning": "The Firestore structure now uses a 'paymentReports' collection which is publicly writable, simplifying the checkout process by removing the need for user authentication at the time of submission. This resolves persistent security rule issues. Admins can then securely read and manage these reports. The 'orders' collection has been removed."
  }
}
