
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the requesting user is an admin.
     * @return {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      // The user is an admin if their UID exists in the /admins collection or matches a hardcoded UID.
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.uid == "txlhGIPOaQR1zISpvJwMgBzdBIt2";
    }

    /******************* Publicly Readable Collections *******************/
    match /brands/{brandId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /parts/{partId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /******************* Payment Reports Collection Rules *******************/
    
    match /paymentReports/{reportId} {
      // ANYONE can create a payment report. No validation is needed here
      // as it was causing permission issues. The data is validated on the client.
      allow create;
      
      // Only Admins can read, update, or delete payment reports.
      allow get, list, update, delete: if isAdmin();
    }
    
    /******************* Admins Collection Rules *******************/
      match /admins/{uid} {
        allow get, list: if isAdmin();
        allow write: if false; // Prevent client-side modification of admin roles.
    }
  }
}
