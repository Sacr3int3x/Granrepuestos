
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the requesting user is an admin.
     * Admin status is granted if the user's UID exists as a document ID in the `/admins` collection.
     * This provides a secure, server-side way to manage roles without exposing admin logic to the client.
     * The hardcoded UID is a failsafe for the primary developer account.
     * @return {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.uid == "txlhGIPOaQR1zISpvJwMgBzdBIt2";
    }

    /******************* Publicly Readable Collections *******************/
    match /brands/{brandId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /parts/{partId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /******************* Admins Collection Rules *******************/
      match /admins/{uid} {
        allow get, list: if isAdmin();
        allow write: if false; // Prevent client-side modification of admin roles.
    }
  }
}
